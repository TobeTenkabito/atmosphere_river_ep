def safe_nanmean(x):
    x = np.asarray(x)
    x = x[np.isfinite(x)]
    if x.size == 0:
        return np.nan
    return np.nanmean(x)


def area_weighted_mean(data, lats, mask=None):
    """
    Latitude-based area-weighted mean.
    data shape: lat x lon
    lats shape: lat
    """
    data = np.asarray(data, dtype=float)
    data = np.where(np.isfinite(data), data, np.nan)

    if mask is not None:
        data = np.where(mask, data, np.nan)

    weights_lat = np.cos(np.deg2rad(lats))
    weights_2d = weights_lat[:, None] * np.ones(data.shape[1])

    valid = np.isfinite(data)
    if np.sum(valid) == 0:
        return np.nan

    return np.nansum(data[valid] * weights_2d[valid]) / np.nansum(weights_2d[valid])


def fdr_mask_from_pvalues(pvals, alpha=0.05):
    """
    Benjamini-Hochberg FDR correction.
    """
    if not HAS_STATSMODELS:
        return np.full(pvals.shape, False)

    p_flat = pvals.ravel()
    valid = np.isfinite(p_flat)

    reject = np.full(p_flat.shape, False, dtype=bool)
    if np.sum(valid) == 0:
        return reject.reshape(pvals.shape)

    reject_valid, _, _, _ = multipletests(
        p_flat[valid],
        alpha=alpha,
        method="fdr_bh"
    )
    reject[valid] = reject_valid
    return reject.reshape(pvals.shape)


