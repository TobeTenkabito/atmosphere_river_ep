if __name__ == "__main__":

    print("Loading NetCDF datasets...")

    ar_ds = nc.Dataset(AR_FILE)
    precip_ds = nc.Dataset(PRECIP_FILE)

    ar_time = ar_ds.variables["time"][:]
    ar_dates = num2date(
        ar_time,
        units=ar_ds.variables["time"].units,
        calendar=ar_ds.variables["time"].calendar
    )

    precip_time = precip_ds.variables["time"][:]
    precip_dates = num2date(
        precip_time,
        units=precip_ds.variables["time"].units,
        calendar=precip_ds.variables["time"].calendar
    )

    if START_DATE_STR is None:
        START_DATE_STR = input("起始日期（YYYY-MM-DD HH:MM:SS）: ")

    if END_DATE_STR is None:
        END_DATE_STR = input("结束日期（YYYY-MM-DD HH:MM:SS）: ")

    start_date = datetime.strptime(START_DATE_STR, "%Y-%m-%d %H:%M:%S")
    end_date = datetime.strptime(END_DATE_STR, "%Y-%m-%d %H:%M:%S")

    print("Converting dates...")

    ar_dates_pd = pd.to_datetime([
        d.strftime("%Y-%m-%d %H:%M:%S") for d in tqdm(ar_dates, desc="AR dates")
    ])

    precip_dates_pd = pd.to_datetime([
        d.strftime("%Y-%m-%d %H:%M:%S") for d in tqdm(precip_dates, desc="Precip dates")
    ])

    df_ar = pd.DataFrame(
        {"ar_idx": np.arange(len(ar_dates_pd))},
        index=ar_dates_pd
    )

    df_precip = pd.DataFrame(
        {"precip_idx": np.arange(len(precip_dates_pd))},
        index=precip_dates_pd
    )

    df_ar_sel = df_ar[start_date:end_date]
    df_precip_sel = df_precip[start_date:end_date]

    merged_df = df_ar_sel.merge(
        df_precip_sel,
        left_index=True,
        right_index=True,
        how="inner"
    )

    if merged_df.empty:
        raise RuntimeError("指定时间范围内，AR 和 precipitation 文件没有共同时间点。")

    ar_indices = merged_df["ar_idx"].values
    precip_indices = merged_df["precip_idx"].values

    selected_dates_pd = merged_df.index

    if SEASONAL_MONTHS is not None:
        month_mask = np.isin(selected_dates_pd.month, SEASONAL_MONTHS)
        ar_indices = ar_indices[month_mask]
        precip_indices = precip_indices[month_mask]
        selected_dates_pd = selected_dates_pd[month_mask]

        if len(selected_dates_pd) == 0:
            raise RuntimeError(f"指定时间范围和季节 {SEASONAL_MONTHS} 内没有数据。")

    print(f"Matched time steps: {len(selected_dates_pd)}")

    print("Selecting spatial domain...")

    precip_lats_all = precip_ds.variables["latitude"][:]
    precip_lons_all = precip_ds.variables["longitude"][:]

    ar_lats_all = ar_ds.variables["lat"][:]
    ar_lons_all = ar_ds.variables["lon"][:]

    precip_lat_indices = np.where(
        (precip_lats_all >= LAT_MIN) & (precip_lats_all <= LAT_MAX)
    )[0]
    precip_lon_indices = np.where(
        (precip_lons_all >= LON_MIN) & (precip_lons_all <= LON_MAX)
    )[0]

    ar_lat_indices = np.where(
        (ar_lats_all >= LAT_MIN) & (ar_lats_all <= LAT_MAX)
    )[0]
    ar_lon_indices = np.where(
        (ar_lons_all >= LON_MIN) & (ar_lons_all <= LON_MAX)
    )[0]

    precip_lats = precip_lats_all[precip_lat_indices]
    precip_lons = precip_lons_all[precip_lon_indices]

    ar_lats = ar_lats_all[ar_lat_indices]
    ar_lons = ar_lons_all[ar_lon_indices]

    if precip_lats.size > 1 and precip_lats[0] > precip_lats[-1]:
        precip_lats = precip_lats[::-1]
        precip_lat_indices = precip_lat_indices[::-1]

    if ar_lats.size > 1 and ar_lats[0] > ar_lats[-1]:
        ar_lats = ar_lats[::-1]
        ar_lat_indices = ar_lat_indices[::-1]

    print("Reading AR and precipitation arrays...")

    ar_data = ar_ds.variables["ar_happen"][
        ar_indices,
        ar_lat_indices,
        ar_lon_indices
    ].astype(np.int8)

    precip_data = precip_ds.variables["extreme_precipitation_flag"][
        precip_indices,
        precip_lat_indices,
        precip_lon_indices
    ].astype(np.int8)

    if ar_data.shape != precip_data.shape:
        raise RuntimeError(
            f"AR and precipitation data shapes differ: "
            f"AR={ar_data.shape}, Precip={precip_data.shape}. "
            f"Please check grid consistency or regrid before analysis."
        )

    print("Loading and aligning climate mode labels...")

    bucket_labels = get_bucket_labels(selected_dates_pd)

    # Remove time steps with missing labels for each mode only within that mode.
    # The main arrays remain unchanged; masks will handle missing labels.

    print("Precomputing time-wise regional counts for bootstrap...")

    time_counts = precompute_time_counts(ar_data, precip_data)

    print("\nComputing phase-level statistics...")

    summary_df = compute_all_phase_statistics(
        ar_data=ar_data,
        precip_data=precip_data,
        bucket_labels=bucket_labels,
        lats=precip_lats
    )

    summary_csv = os.path.join(OUTPUT_DIR, "mode_phase_summary_statistics.csv")
    summary_df.to_csv(summary_csv, index=False, encoding="utf-8-sig")
    print(f"Saved: {summary_csv}")

    print("\nComputing pairwise phase differences...")

    diff_df = compute_phase_differences(
        summary_df=summary_df,
        bucket_labels=bucket_labels,
        dates_pd=selected_dates_pd,
        time_counts=time_counts
    )

    diff_csv = os.path.join(OUTPUT_DIR, "mode_phase_pairwise_differences.csv")
    diff_df.to_csv(diff_csv, index=False, encoding="utf-8-sig")
    print(f"Saved: {diff_csv}")

    # Save Excel workbook if possible
    excel_file = os.path.join(OUTPUT_DIR, "mode_attribution_statistics_tables.xlsx")
    try:
        with pd.ExcelWriter(excel_file) as writer:
            summary_df.to_excel(writer, sheet_name="phase_summary", index=False)
            diff_df.to_excel(writer, sheet_name="phase_differences", index=False)
        print(f"Saved: {excel_file}")
    except Exception as e:
        print(f"Excel output failed, but CSV files were saved. Reason: {e}")

    report_file = os.path.join(OUTPUT_DIR, "mode_attribution_report.txt")
    write_text_report(summary_df, diff_df, report_file)
    print(f"Saved: {report_file}")

    ar_ds.close()
    precip_ds.close()

    print("\nAll statistics completed.")
    print("Output directory:", OUTPUT_DIR)
