# 4. Metric calculation
# ============================================================

def compute_grid_counts(ar_subset, precip_subset):
    A = np.sum((ar_subset == 1) & (precip_subset == 1), axis=0)
    B = np.sum((ar_subset == 1) & (precip_subset == 0), axis=0)
    C = np.sum((ar_subset == 0) & (precip_subset == 1), axis=0)
    D = np.sum((ar_subset == 0) & (precip_subset == 0), axis=0)

    return A, B, C, D


def compute_grid_metrics(A, B, C, D):
    A = A.astype(float)
    B = B.astype(float)
    C = C.astype(float)
    D = D.astype(float)

    N = A + B + C + D

    denom_ar = A + B
    denom_no_ar = C + D

    p_ext_ar = np.where(denom_ar > 0, A / denom_ar, np.nan)
    p_ext_no_ar = np.where(denom_no_ar > 0, C / denom_no_ar, np.nan)

    RD = p_ext_ar - p_ext_no_ar
    RR = np.where(p_ext_no_ar > 0, p_ext_ar / p_ext_no_ar, np.nan)

    AF = np.where(p_ext_ar > 0, (p_ext_ar - p_ext_no_ar) / p_ext_ar, np.nan)

    freq_e = np.where(N > 0, (A + C) / N, np.nan)
    p_not_ar = np.where(N > 0, (C + D) / N, np.nan)

    PAF = np.where(
        freq_e > 0,
        (freq_e - p_not_ar * p_ext_no_ar) / freq_e,
        np.nan
    )

    return {
        "p_ext_ar": p_ext_ar,
        "p_ext_no_ar": p_ext_no_ar,
        "RD": RD,
        "RR": RR,
        "AF": AF,
        "PAF": PAF
    }


def fisher_grid_pvalues(A, B, C, D, desc="Fisher test"):
    p_sig = np.full(A.shape, np.nan, dtype=float)

    nlat, nlon = A.shape
    total = nlat * nlon

    with tqdm(total=total, desc=desc) as pbar:
        for i in range(nlat):
            for j in range(nlon):
                table = [[int(A[i, j]), int(B[i, j])],
                         [int(C[i, j]), int(D[i, j])]]

                if np.sum(table) > 0:
                    _, p = fisher_exact(table, alternative="greater")
                    p_sig[i, j] = p

                pbar.update(1)

    return p_sig


def pooled_delta_ci(A, B, C, D, alpha=0.05, cc=0.5):
    """
    Regionally pooled estimate and delta-method CI.

    A: AR and EP
    B: AR and no EP
    C: no AR and EP
    D: no AR and no EP
    """
    A_raw, B_raw, C_raw, D_raw = A, B, C, D

    A_c = A + (cc if A == 0 else 0)
    B_c = B + (cc if B == 0 else 0)
    C_c = C + (cc if C == 0 else 0)
    D_c = D + (cc if D == 0 else 0)

    n1 = A_c + B_c
    n0 = C_c + D_c
    total = A_raw + B_raw + C_raw + D_raw

    if n1 <= 0 or n0 <= 0 or total <= 0:
        return empty_pooled_result()

    p1 = A_c / n1
    p0 = C_c / n0

    if p0 <= 0:
        return empty_pooled_result()

    z = norm.ppf(1 - alpha / 2)

    RD = p1 - p0
    var_RD = p1 * (1 - p1) / n1 + p0 * (1 - p0) / n0
    se_RD = np.sqrt(max(var_RD, 0))

    RD_lo = RD - z * se_RD
    RD_hi = RD + z * se_RD

    RR = p1 / p0

    var_logRR = (1.0 / A_c) - (1.0 / n1) + (1.0 / C_c) - (1.0 / n0)
    var_logRR = max(var_logRR, 0)
    se_logRR = np.sqrt(var_logRR)

    RR_lo = np.exp(np.log(RR) - z * se_logRR)
    RR_hi = np.exp(np.log(RR) + z * se_logRR)

    AF = 1.0 - 1.0 / RR
    se_AF = se_logRR / RR
    AF_lo = AF - z * se_AF
    AF_hi = AF + z * se_AF

    p_exp = (A_raw + B_raw) / total
    denom = 1.0 + p_exp * (RR - 1.0)

    if denom == 0:
        PAF = np.nan
        PAF_lo = np.nan
        PAF_hi = np.nan
    else:
        PAF = (p_exp * (RR - 1.0)) / denom
        deriv = (p_exp * RR) / (denom ** 2)
        se_PAF = se_logRR * deriv
        PAF_lo = PAF - z * se_PAF
        PAF_hi = PAF + z * se_PAF

    return {
        "pooled_p_ext_ar": p1,
        "pooled_p_ext_no_ar": p0,

        "pooled_RD": RD,
        "pooled_RD_lo": RD_lo,
        "pooled_RD_hi": RD_hi,

        "pooled_RR": RR,
        "pooled_RR_lo": RR_lo,
        "pooled_RR_hi": RR_hi,

        "pooled_AF": AF,
        "pooled_AF_lo": AF_lo,
        "pooled_AF_hi": AF_hi,

        "pooled_PAF": PAF,
        "pooled_PAF_lo": PAF_lo,
        "pooled_PAF_hi": PAF_hi,

        "pooled_AR_fraction": (A_raw + B_raw) / total if total > 0 else np.nan,
        "pooled_EP_fraction": (A_raw + C_raw) / total if total > 0 else np.nan,

        "A_total": A_raw,
        "B_total": B_raw,
        "C_total": C_raw,
        "D_total": D_raw,
        "N_total": total
    }


def empty_pooled_result():
    keys = [
        "pooled_p_ext_ar", "pooled_p_ext_no_ar",
        "pooled_RD", "pooled_RD_lo", "pooled_RD_hi",
        "pooled_RR", "pooled_RR_lo", "pooled_RR_hi",
        "pooled_AF", "pooled_AF_lo", "pooled_AF_hi",
        "pooled_PAF", "pooled_PAF_lo", "pooled_PAF_hi",
        "pooled_AR_fraction", "pooled_EP_fraction",
        "A_total", "B_total", "C_total", "D_total", "N_total"
    ]
    return {k: np.nan for k in keys}


