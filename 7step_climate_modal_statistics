def write_text_report(summary_df, diff_df, output_file):
    with open(output_file, "w", encoding="utf-8") as f:
        f.write("=== AR attribution under climate-mode phases ===\n\n")

        f.write("Mode lag settings:\n")
        for mode, lag in MONTHLY_MODE_LAGS.items():
            f.write(f"  {mode}: lag = {lag} months\n")
        for mode, lag in DAILY_MODE_LAGS.items():
            f.write(f"  {mode}: lag = {lag} days\n")

        f.write("\nSignificance settings:\n")
        f.write(f"  Fisher one-sided test: alternative='greater'\n")
        f.write(f"  p-value threshold: {SIG_LEVEL}\n")
        f.write(f"  FDR correction used: {USE_FDR and HAS_STATSMODELS}\n")
        f.write(f"  Bootstrap used: {RUN_BOOTSTRAP}\n")
        if RUN_BOOTSTRAP:
            f.write(f"  Bootstrap repetitions: {N_BOOT}\n")
            f.write(f"  Bootstrap block: {BOOTSTRAP_BLOCK}\n")

        f.write("\n\n=== Phase-level summary ===\n")

        cols = [
            "Mode", "Phase", "Time_points",
            "Significant_grids_p05", "Significant_grids_FDR",
            "Mean_P_EP_AR_sig", "Mean_P_EP_noAR_sig",
            "Mean_RD_sig", "Mean_RR_sig", "Mean_AF_sig", "Mean_PAF_sig",
            "AW_Mean_RD_sig", "AW_Mean_AF_sig", "AW_Mean_PAF_sig",
            "pooled_RD", "pooled_RD_lo", "pooled_RD_hi",
            "pooled_RR", "pooled_RR_lo", "pooled_RR_hi",
            "pooled_AF", "pooled_AF_lo", "pooled_AF_hi",
            "pooled_PAF", "pooled_PAF_lo", "pooled_PAF_hi"
        ]

        existing_cols = [c for c in cols if c in summary_df.columns]
        f.write(summary_df[existing_cols].to_string(index=False))
        f.write("\n\n")

        f.write("=== Pairwise phase differences ===\n")

        if diff_df is not None and len(diff_df) > 0:
            diff_cols = [
                "Comparison",
                "Diff_AW_Mean_AF_sig",
                "Diff_AW_Mean_PAF_sig",
                "Diff_AW_Mean_RD_sig",
                "Diff_Pooled_AF",
                "Diff_Pooled_PAF",
                "Diff_Pooled_RD",
                "Bootstrap_AF_CI_low",
                "Bootstrap_AF_CI_high",
                "Bootstrap_AF_p_two_sided",
                "Bootstrap_AF_significant",
                "Bootstrap_PAF_CI_low",
                "Bootstrap_PAF_CI_high",
                "Bootstrap_PAF_p_two_sided",
                "Bootstrap_PAF_significant",
                "Bootstrap_RD_CI_low",
                "Bootstrap_RD_CI_high",
                "Bootstrap_RD_p_two_sided",
                "Bootstrap_RD_significant"
            ]

            existing_diff_cols = [c for c in diff_cols if c in diff_df.columns]
            f.write(diff_df[existing_diff_cols].to_string(index=False))
        else:
            f.write("No pairwise differences computed.\n")

        f.write("\n\n=== Interpretation note ===\n")
        f.write(
            "The within-phase Fisher test evaluates whether AR increases EP probability "
            "under a given mode phase. It does not by itself test whether two phases differ. "
            "Pairwise phase differences and bootstrap confidence intervals should be used "
            "to assess whether a climate mode significantly modulates AR-related attribution.\n"
        )


