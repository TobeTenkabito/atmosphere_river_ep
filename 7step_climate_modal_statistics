def precompute_time_counts(ar_data, precip_data):
    """
    Per-time regional pooled counts.
    This makes bootstrap much faster.
    """
    A_t = np.sum((ar_data == 1) & (precip_data == 1), axis=(1, 2)).astype(np.int64)
    B_t = np.sum((ar_data == 1) & (precip_data == 0), axis=(1, 2)).astype(np.int64)
    C_t = np.sum((ar_data == 0) & (precip_data == 1), axis=(1, 2)).astype(np.int64)
    D_t = np.sum((ar_data == 0) & (precip_data == 0), axis=(1, 2)).astype(np.int64)

    return {
        "A": A_t,
        "B": B_t,
        "C": C_t,
        "D": D_t
    }


def pooled_point_from_counts(A, B, C, D):
    res = pooled_delta_ci(A, B, C, D)
    return {
        "RD": res["pooled_RD"],
        "RR": res["pooled_RR"],
        "AF": res["pooled_AF"],
        "PAF": res["pooled_PAF"]
    }


def build_month_blocks_for_bucket(labels, bucket, dates_pd, time_counts):
    """
    Build year-month blocks for one phase.
    Each block contains all time points belonging to that phase within one month.
    """
    labels = np.asarray(labels, dtype=object)
    idx = np.where(labels == bucket)[0]

    if idx.size == 0:
        return None

    dates_sel = pd.to_datetime(dates_pd[idx])
    months = dates_sel.to_period("M")

    block_rows = []

    for month in np.unique(months):
        block_idx = idx[months == month]

        block_rows.append({
            "month": str(month),
            "A": int(np.sum(time_counts["A"][block_idx])),
            "B": int(np.sum(time_counts["B"][block_idx])),
            "C": int(np.sum(time_counts["C"][block_idx])),
            "D": int(np.sum(time_counts["D"][block_idx])),
            "n_time": int(len(block_idx))
        })

    return pd.DataFrame(block_rows)


def bootstrap_pooled_difference(
    labels,
    bucket1,
    bucket2,
    dates_pd,
    time_counts,
    n_boot=500,
    seed=42
):
    rng = np.random.default_rng(seed)

    blocks1 = build_month_blocks_for_bucket(labels, bucket1, dates_pd, time_counts)
    blocks2 = build_month_blocks_for_bucket(labels, bucket2, dates_pd, time_counts)

    if blocks1 is None or blocks2 is None:
        return None

    if len(blocks1) < 3 or len(blocks2) < 3:
        return None

    boot_diffs = {
        "RD": [],
        "RR": [],
        "AF": [],
        "PAF": []
    }

    n1 = len(blocks1)
    n2 = len(blocks2)

    vals1 = blocks1[["A", "B", "C", "D"]].to_numpy()
    vals2 = blocks2[["A", "B", "C", "D"]].to_numpy()

    for _ in range(n_boot):
        sample1 = rng.integers(0, n1, size=n1)
        sample2 = rng.integers(0, n2, size=n2)

        A1, B1, C1, D1 = np.sum(vals1[sample1], axis=0)
        A2, B2, C2, D2 = np.sum(vals2[sample2], axis=0)

        m1 = pooled_point_from_counts(A1, B1, C1, D1)
        m2 = pooled_point_from_counts(A2, B2, C2, D2)

        for metric in boot_diffs:
            boot_diffs[metric].append(m1[metric] - m2[metric])

    out = {}

    for metric, diffs in boot_diffs.items():
        diffs = np.asarray(diffs, dtype=float)
        diffs = diffs[np.isfinite(diffs)]

        if diffs.size == 0:
            out[f"Bootstrap_{metric}_mean_diff"] = np.nan
            out[f"Bootstrap_{metric}_CI_low"] = np.nan
            out[f"Bootstrap_{metric}_CI_high"] = np.nan
            out[f"Bootstrap_{metric}_p_two_sided"] = np.nan
            out[f"Bootstrap_{metric}_significant"] = False
            continue

        ci_low, ci_high = np.percentile(diffs, [2.5, 97.5])

        p_two = 2 * min(
            np.mean(diffs <= 0),
            np.mean(diffs >= 0)
        )
        p_two = min(p_two, 1.0)

        out[f"Bootstrap_{metric}_mean_diff"] = np.mean(diffs)
        out[f"Bootstrap_{metric}_CI_low"] = ci_low
        out[f"Bootstrap_{metric}_CI_high"] = ci_high
        out[f"Bootstrap_{metric}_p_two_sided"] = p_two
        out[f"Bootstrap_{metric}_significant"] = bool((ci_low > 0) or (ci_high < 0))

    out["Bootstrap_blocks_phase1"] = n1
    out["Bootstrap_blocks_phase2"] = n2

    return out


def get_default_phase_comparisons():
    return {
        "ENSO": [
            ("ElNino", "LaNina"),
            ("ElNino", "Neutral"),
            ("LaNina", "Neutral")
        ],
        "MJO": [
            ("Active_1to4", "Active_5to8"),
            ("Active_1to4", "Inactive"),
            ("Active_5to8", "Inactive")
        ],
        "AO": [
            ("Positive", "Negative"),
            ("Negative", "Neutral"),
            ("Positive", "Neutral")
        ],
        "PDO": [
            ("Positive", "Negative"),
            ("Positive", "Neutral"),
            ("Neutral", "Negative")
        ]
    }


def compute_phase_differences(summary_df, bucket_labels, dates_pd, time_counts):
    comparisons = get_default_phase_comparisons()

    rows = []

    for mode, pairs in comparisons.items():
        if mode not in CONTROL_MODES:
            continue

        mode_df = summary_df[summary_df["Mode"] == mode].copy()
        available = set(mode_df["Phase"].astype(str).to_list())

        for phase1, phase2 in pairs:
            if phase1 not in available or phase2 not in available:
                continue

            r1 = mode_df[mode_df["Phase"] == phase1].iloc[0]
            r2 = mode_df[mode_df["Phase"] == phase2].iloc[0]

            row = {
                "Mode": mode,
                "Phase1": phase1,
                "Phase2": phase2,
                "Comparison": f"{mode}: {phase1} - {phase2}",

                "Time_points_phase1": r1["Time_points"],
                "Time_points_phase2": r2["Time_points"],

                "Diff_Mean_AF_sig": r1["Mean_AF_sig"] - r2["Mean_AF_sig"],
                "Diff_Mean_PAF_sig": r1["Mean_PAF_sig"] - r2["Mean_PAF_sig"],
                "Diff_Mean_RD_sig": r1["Mean_RD_sig"] - r2["Mean_RD_sig"],
                "Diff_Mean_RR_sig": r1["Mean_RR_sig"] - r2["Mean_RR_sig"],

                "Diff_AW_Mean_AF_sig": r1["AW_Mean_AF_sig"] - r2["AW_Mean_AF_sig"],
                "Diff_AW_Mean_PAF_sig": r1["AW_Mean_PAF_sig"] - r2["AW_Mean_PAF_sig"],
                "Diff_AW_Mean_RD_sig": r1["AW_Mean_RD_sig"] - r2["AW_Mean_RD_sig"],
                "Diff_AW_Mean_RR_sig": r1["AW_Mean_RR_sig"] - r2["AW_Mean_RR_sig"],

                "Diff_Pooled_AF": r1["pooled_AF"] - r2["pooled_AF"],
                "Diff_Pooled_PAF": r1["pooled_PAF"] - r2["pooled_PAF"],
                "Diff_Pooled_RD": r1["pooled_RD"] - r2["pooled_RD"],
                "Diff_Pooled_RR": r1["pooled_RR"] - r2["pooled_RR"],
            }

            if RUN_BOOTSTRAP:
                print(f"\nBootstrap comparison: {mode} {phase1} - {phase2}")
                boot = bootstrap_pooled_difference(
                    labels=bucket_labels[mode],
                    bucket1=phase1,
                    bucket2=phase2,
                    dates_pd=dates_pd,
                    time_counts=time_counts,
                    n_boot=N_BOOT,
                    seed=BOOTSTRAP_SEED
                )

                if boot is not None:
                    row.update(boot)
                else:
                    row["Bootstrap_note"] = "Not enough blocks or missing phase"

            rows.append(row)

    return pd.DataFrame(rows)


