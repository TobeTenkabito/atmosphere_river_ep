def load_enso():
    df = pd.read_csv(ENSO_FILE, header=1, index_col=0)
    df.index = pd.to_datetime(df.index, errors="coerce", format="mixed")
    df = df.dropna(subset=[df.columns[0]])

    values = df.iloc[:, 0].astype(float)

    bucket = pd.Series(index=values.index, dtype="object")
    bucket[values > 0.5] = "ElNino"
    bucket[values < -0.5] = "LaNina"
    bucket[(values >= -0.5) & (values <= 0.5)] = "Neutral"

    return bucket.dropna()


def load_mjo():
    df = pd.read_csv(MJO_FILE, header=2)
    df.columns = [
        "year", "month", "day",
        "RMM1", "RMM2", "RMM_phase", "RMM_amplitude",
        "RMM_weight", "Column9", "Column10"
    ]

    df["time"] = pd.to_datetime(df[["year", "month", "day"]], errors="coerce")
    df = df.dropna(subset=["time"])
    df = df.set_index("time").sort_index()

    amp = df["RMM_amplitude"].astype(float)
    phase = df["RMM_phase"].astype(float)

    bucket = pd.Series(index=df.index, dtype="object")
    bucket[amp < 1] = "Inactive"
    bucket[(amp >= 1) & (phase.isin([1, 2, 3, 4]))] = "Active_1to4"
    bucket[(amp >= 1) & (phase.isin([5, 6, 7, 8]))] = "Active_5to8"

    return bucket.dropna()


def load_ao():
    df = pd.read_csv(AO_FILE)
    df["time"] = pd.to_datetime(
        df["year"].astype(str) + "-" + df["month"].astype(str),
        format="%Y-%m"
    )
    df = df.set_index("time").sort_index()

    values = df["index"].astype(float)

    bucket = pd.Series(index=values.index, dtype="object")
    bucket[values > 0.5] = "Positive"
    bucket[values < -0.5] = "Negative"
    bucket[(values >= -0.5) & (values <= 0.5)] = "Neutral"

    return bucket.dropna()


def load_pdo():
    df = pd.read_csv(PDO_FILE)

    df_long = pd.melt(
        df,
        id_vars=["Year"],
        var_name="Month",
        value_name="index"
    )

    month_map = {
        "Jan": 1, "Feb": 2, "Mar": 3, "Apr": 4,
        "May": 5, "Jun": 6, "Jul": 7, "Aug": 8,
        "Sep": 9, "Oct": 10, "Nov": 11, "Dec": 12
    }

    df_long["MonthNum"] = df_long["Month"].map(month_map)
    df_long["time"] = pd.to_datetime(
        df_long["Year"].astype(str) + "-" + df_long["MonthNum"].astype(str),
        format="%Y-%m"
    )

    df_long = df_long.set_index("time").sort_index()
    values = df_long["index"].astype(float)

    bucket = pd.Series(index=values.index, dtype="object")
    bucket[values > 0.5] = "Positive"
    bucket[values < -0.5] = "Negative"
    bucket[(values >= -0.5) & (values <= 0.5)] = "Neutral"

    return bucket.dropna()


def shift_monthly_series(series, lag_months):
    """
    Monthly lag.
    Positive lag means the mode index is shifted forward in calendar time.
    """
    s = series.copy()
    s.index = pd.to_datetime(s.index).to_period("M").to_timestamp()

    if lag_months != 0:
        s.index = s.index + pd.DateOffset(months=lag_months)

    return s.sort_index()


def shift_daily_series(series, lag_days):
    """
    Daily lag.
    Positive lag means the mode index is shifted forward in calendar time.
    """
    s = series.copy()
    s.index = pd.to_datetime(s.index).normalize()

    if lag_days != 0:
        s.index = s.index + pd.DateOffset(days=lag_days)

    return s.sort_index()


def align_monthly_bucket_to_daily(monthly_series, daily_dates):
    """
    Align monthly mode labels to daily dates by calendar month.
    This avoids nearest-month matching problems.
    """
    s = monthly_series.copy()
    s.index = pd.to_datetime(s.index).to_period("M")

    target_month = pd.to_datetime(daily_dates).to_period("M")
    aligned = s.reindex(target_month)

    return aligned.to_numpy(dtype=object)


def align_daily_bucket_to_daily(daily_series, daily_dates):
    """
    Align daily mode labels to daily dates by exact normalized date.
    """
    s = daily_series.copy()
    s.index = pd.to_datetime(s.index).normalize()

    target = pd.to_datetime(daily_dates).normalize()
    aligned = s.reindex(target)

    return aligned.to_numpy(dtype=object)


def get_bucket_labels(dates_pd):
    labels = {}

    if "ENSO" in CONTROL_MODES:
        enso = load_enso()
        enso = shift_monthly_series(enso, MONTHLY_MODE_LAGS.get("ENSO", 0))
        labels["ENSO"] = align_monthly_bucket_to_daily(enso, dates_pd)

    if "MJO" in CONTROL_MODES:
        mjo = load_mjo()
        mjo = shift_daily_series(mjo, DAILY_MODE_LAGS.get("MJO", 0))
        labels["MJO"] = align_daily_bucket_to_daily(mjo, dates_pd)

    if "AO" in CONTROL_MODES:
        ao = load_ao()
        ao = shift_monthly_series(ao, MONTHLY_MODE_LAGS.get("AO", 0))
        labels["AO"] = align_monthly_bucket_to_daily(ao, dates_pd)

    if "PDO" in CONTROL_MODES:
        pdo = load_pdo()
        pdo = shift_monthly_series(pdo, MONTHLY_MODE_LAGS.get("PDO", 0))
        labels["PDO"] = align_monthly_bucket_to_daily(pdo, dates_pd)

    return labels


