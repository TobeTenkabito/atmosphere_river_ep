def summarize_one_bucket(mode, bucket, mask, ar_data, precip_data, lats):
    n_time = int(np.sum(mask))

    ar_subset = ar_data[mask]
    precip_subset = precip_data[mask]

    A, B, C, D = compute_grid_counts(ar_subset, precip_subset)
    metrics = compute_grid_metrics(A, B, C, D)

    p_sig = fisher_grid_pvalues(
        A, B, C, D,
        desc=f"Fisher: {mode}={bucket}"
    )

    sig_mask = p_sig < SIG_LEVEL

    if USE_FDR and HAS_STATSMODELS:
        fdr_mask = fdr_mask_from_pvalues(p_sig, alpha=SIG_LEVEL)
    else:
        fdr_mask = np.full(p_sig.shape, False, dtype=bool)

    A_tot = int(np.nansum(A))
    B_tot = int(np.nansum(B))
    C_tot = int(np.nansum(C))
    D_tot = int(np.nansum(D))

    pooled = pooled_delta_ci(A_tot, B_tot, C_tot, D_tot)

    row = {
        "Mode": mode,
        "Phase": bucket,
        "Time_points": n_time,

        "Significant_grids_p05": int(np.sum(sig_mask)),
        "Significant_grids_FDR": int(np.sum(fdr_mask)) if HAS_STATSMODELS else np.nan,

        "Mean_P_EP_AR_all": safe_nanmean(metrics["p_ext_ar"]),
        "Mean_P_EP_noAR_all": safe_nanmean(metrics["p_ext_no_ar"]),
        "Mean_RD_all": safe_nanmean(metrics["RD"]),
        "Mean_RR_all": safe_nanmean(metrics["RR"]),
        "Mean_AF_all": safe_nanmean(metrics["AF"]),
        "Mean_PAF_all": safe_nanmean(metrics["PAF"]),

        "Mean_P_EP_AR_sig": safe_nanmean(metrics["p_ext_ar"][sig_mask]),
        "Mean_P_EP_noAR_sig": safe_nanmean(metrics["p_ext_no_ar"][sig_mask]),
        "Mean_RD_sig": safe_nanmean(metrics["RD"][sig_mask]),
        "Mean_RR_sig": safe_nanmean(metrics["RR"][sig_mask]),
        "Mean_AF_sig": safe_nanmean(metrics["AF"][sig_mask]),
        "Mean_PAF_sig": safe_nanmean(metrics["PAF"][sig_mask]),

        "AW_Mean_P_EP_AR_all": area_weighted_mean(metrics["p_ext_ar"], lats),
        "AW_Mean_P_EP_noAR_all": area_weighted_mean(metrics["p_ext_no_ar"], lats),
        "AW_Mean_RD_all": area_weighted_mean(metrics["RD"], lats),
        "AW_Mean_RR_all": area_weighted_mean(metrics["RR"], lats),
        "AW_Mean_AF_all": area_weighted_mean(metrics["AF"], lats),
        "AW_Mean_PAF_all": area_weighted_mean(metrics["PAF"], lats),

        "AW_Mean_P_EP_AR_sig": area_weighted_mean(metrics["p_ext_ar"], lats, sig_mask),
        "AW_Mean_P_EP_noAR_sig": area_weighted_mean(metrics["p_ext_no_ar"], lats, sig_mask),
        "AW_Mean_RD_sig": area_weighted_mean(metrics["RD"], lats, sig_mask),
        "AW_Mean_RR_sig": area_weighted_mean(metrics["RR"], lats, sig_mask),
        "AW_Mean_AF_sig": area_weighted_mean(metrics["AF"], lats, sig_mask),
        "AW_Mean_PAF_sig": area_weighted_mean(metrics["PAF"], lats, sig_mask),
    }

    row.update(pooled)

    return row


def compute_all_phase_statistics(ar_data, precip_data, bucket_labels, lats):
    rows = []

    for mode in CONTROL_MODES:
        labels = np.asarray(bucket_labels[mode], dtype=object)
        valid = pd.notna(labels)

        buckets = sorted(np.unique(labels[valid]))

        for bucket in buckets:
            mask = labels == bucket
            n_time = int(np.sum(mask))

            if n_time == 0:
                continue

            print(f"\n--- Computing statistics for {mode}={bucket}, n={n_time} ---")

            row = summarize_one_bucket(
                mode=mode,
                bucket=bucket,
                mask=mask,
                ar_data=ar_data,
                precip_data=precip_data,
                lats=lats
            )

            rows.append(row)

    return pd.DataFrame(rows)


