def safe_divide(a, b):
    if b == 0 or pd.isna(b):
        return np.nan
    return a / b


def phase_sort_key(x):
    """
    Sort phases in a physically meaningful order.
    """
    x = str(x)
    if x == "Inactive":
        return 0
    if x.startswith("Phase_"):
        try:
            return int(x.split("_")[1])
        except Exception:
            return 99
    order = {
        "ElNino": 1,
        "LaNina": 2,
        "Neutral": 3,
        "Negative": 1,
        "Positive": 2,
        "Active_1to4": 1,
        "Active_5to8": 2
    }
    return order.get(x, 99)


def add_fdr_correction(diff_df):
    """
    Add global FDR-corrected q-values for bootstrap p-values.
    """
    if diff_df is None or len(diff_df) == 0:
        return diff_df

    if not HAS_STATSMODELS:
        return diff_df

    for metric in ["AF", "PAF", "RD", "RR"]:
        pcol = f"Bootstrap_{metric}_p_two_sided"
        if pcol not in diff_df.columns:
            continue

        qcol = f"Bootstrap_{metric}_q_global"
        sigcol = f"Bootstrap_{metric}_significant_FDR"

        pvals = diff_df[pcol].to_numpy(dtype=float)
        valid = np.isfinite(pvals)

        qvals = np.full_like(pvals, np.nan, dtype=float)
        reject = np.full_like(valid, False, dtype=bool)

        if np.sum(valid) > 0:
            reject_valid, q_valid, _, _ = multipletests(
                pvals[valid],
                alpha=0.05,
                method="fdr_bh"
            )
            qvals[valid] = q_valid
            reject[valid] = reject_valid

        diff_df[qcol] = qvals
        diff_df[sigcol] = reject

    return diff_df


