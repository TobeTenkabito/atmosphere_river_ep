# 4. Pooled statistics
# ============================================================

def pooled_delta_ci(A, B, C, D, alpha=0.05, cc=0.5):
    """
    Regionally pooled estimate and delta-method CI.

    A: AR and EP
    B: AR and no EP
    C: no AR and EP
    D: no AR and no EP
    """
    A_raw, B_raw, C_raw, D_raw = int(A), int(B), int(C), int(D)

    A_c = A_raw + (cc if A_raw == 0 else 0)
    B_c = B_raw + (cc if B_raw == 0 else 0)
    C_c = C_raw + (cc if C_raw == 0 else 0)
    D_c = D_raw + (cc if D_raw == 0 else 0)

    n1 = A_c + B_c
    n0 = C_c + D_c
    total = A_raw + B_raw + C_raw + D_raw

    if n1 <= 0 or n0 <= 0 or total <= 0:
        return empty_pooled_result()

    p1 = A_c / n1
    p0 = C_c / n0

    if p0 <= 0:
        return empty_pooled_result()

    z = norm.ppf(1 - alpha / 2)

    RD = p1 - p0
    var_RD = p1 * (1 - p1) / n1 + p0 * (1 - p0) / n0
    se_RD = np.sqrt(max(var_RD, 0))

    RD_lo = RD - z * se_RD
    RD_hi = RD + z * se_RD

    RR = p1 / p0

    var_logRR = (1.0 / A_c) - (1.0 / n1) + (1.0 / C_c) - (1.0 / n0)
    var_logRR = max(var_logRR, 0)
    se_logRR = np.sqrt(var_logRR)

    RR_lo = np.exp(np.log(RR) - z * se_logRR)
    RR_hi = np.exp(np.log(RR) + z * se_logRR)

    AF = 1.0 - 1.0 / RR
    se_AF = se_logRR / RR

    AF_lo = AF - z * se_AF
    AF_hi = AF + z * se_AF

    p_exp = (A_raw + B_raw) / total
    ep_frac = (A_raw + C_raw) / total

    denom = 1.0 + p_exp * (RR - 1.0)

    if denom == 0:
        PAF = np.nan
        PAF_lo = np.nan
        PAF_hi = np.nan
    else:
        PAF = (p_exp * (RR - 1.0)) / denom
        deriv = (p_exp * RR) / (denom ** 2)
        se_PAF = se_logRR * deriv
        PAF_lo = PAF - z * se_PAF
        PAF_hi = PAF + z * se_PAF

    return {
        "pooled_p_ext_ar": p1,
        "pooled_p_ext_no_ar": p0,

        "pooled_RD": RD,
        "pooled_RD_lo": RD_lo,
        "pooled_RD_hi": RD_hi,

        "pooled_RR": RR,
        "pooled_RR_lo": RR_lo,
        "pooled_RR_hi": RR_hi,

        "pooled_AF": AF,
        "pooled_AF_lo": AF_lo,
        "pooled_AF_hi": AF_hi,

        "pooled_PAF": PAF,
        "pooled_PAF_lo": PAF_lo,
        "pooled_PAF_hi": PAF_hi,

        "pooled_AR_fraction": p_exp,
        "pooled_EP_fraction": ep_frac,

        "A_total": A_raw,
        "B_total": B_raw,
        "C_total": C_raw,
        "D_total": D_raw,
        "N_total": total
    }


def empty_pooled_result():
    keys = [
        "pooled_p_ext_ar", "pooled_p_ext_no_ar",
        "pooled_RD", "pooled_RD_lo", "pooled_RD_hi",
        "pooled_RR", "pooled_RR_lo", "pooled_RR_hi",
        "pooled_AF", "pooled_AF_lo", "pooled_AF_hi",
        "pooled_PAF", "pooled_PAF_lo", "pooled_PAF_hi",
        "pooled_AR_fraction", "pooled_EP_fraction",
        "A_total", "B_total", "C_total", "D_total", "N_total"
    ]
    return {k: np.nan for k in keys}


def precompute_time_counts(ar_data, precip_data):
    """
    Per-time regional pooled counts.
    This is much faster than recalculating from 3D arrays for every lag.
    """
    A_t = np.sum((ar_data == 1) & (precip_data == 1), axis=(1, 2)).astype(np.int64)
    B_t = np.sum((ar_data == 1) & (precip_data == 0), axis=(1, 2)).astype(np.int64)
    C_t = np.sum((ar_data == 0) & (precip_data == 1), axis=(1, 2)).astype(np.int64)
    D_t = np.sum((ar_data == 0) & (precip_data == 0), axis=(1, 2)).astype(np.int64)

    return {
        "A": A_t,
        "B": B_t,
        "C": C_t,
        "D": D_t
    }


def summarize_phase_pooled(mode, lag, phase, labels, time_counts):
    labels = np.asarray(labels, dtype=object)
    idx = np.where(labels == phase)[0]

    if idx.size == 0:
        return None

    A = int(np.sum(time_counts["A"][idx]))
    B = int(np.sum(time_counts["B"][idx]))
    C = int(np.sum(time_counts["C"][idx]))
    D = int(np.sum(time_counts["D"][idx]))

    pooled = pooled_delta_ci(A, B, C, D)

    row = {
        "Mode": mode,
        "Lag": lag,
        "Lag_unit": MODE_LAG_UNIT[mode],
        "Phase": phase,
        "Time_points": int(idx.size)
    }

    row.update(pooled)

    return row


def compute_phase_summary_for_mode_lag(mode, lag, labels, time_counts):
    labels = np.asarray(labels, dtype=object)
    valid = pd.notna(labels)
    phases = sorted(np.unique(labels[valid]), key=phase_sort_key)

    rows = []
    for phase in phases:
        row = summarize_phase_pooled(
            mode=mode,
            lag=lag,
            phase=phase,
            labels=labels,
            time_counts=time_counts
        )
        if row is not None:
            rows.append(row)

    return pd.DataFrame(rows)


