def run_lag_scan(raw_mode_series, dates_pd, time_counts):
    all_summary = []
    all_diffs = []

    for mode in CONTROL_MODES:
        print(f"\n==============================")
        print(f"Running lag scan for {mode}")
        print(f"==============================")

        raw_series = raw_mode_series[mode]
        lags = LAG_SCAN[mode]

        for lag in lags:
            print(f"\n--- {mode}, lag={lag} {MODE_LAG_UNIT[mode]} ---")

            labels = get_lagged_labels_for_mode(
                mode=mode,
                raw_series=raw_series,
                dates_pd=dates_pd,
                lag=lag
            )

            n_valid = np.sum(pd.notna(labels))
            print(f"Valid labels: {n_valid}/{len(labels)}")

            if n_valid == 0:
                continue

            summary_lag = compute_phase_summary_for_mode_lag(
                mode=mode,
                lag=lag,
                labels=labels,
                time_counts=time_counts
            )

            if summary_lag is not None and len(summary_lag) > 0:
                all_summary.append(summary_lag)

            diff_lag = compute_pairwise_differences_for_mode_lag(
                mode=mode,
                lag=lag,
                labels=labels,
                summary_df=summary_lag,
                dates_pd=dates_pd,
                time_counts=time_counts
            )

            if diff_lag is not None and len(diff_lag) > 0:
                all_diffs.append(diff_lag)

    summary_df = pd.concat(all_summary, ignore_index=True) if all_summary else pd.DataFrame()
    diff_df = pd.concat(all_diffs, ignore_index=True) if all_diffs else pd.DataFrame()

    diff_df = add_fdr_correction(diff_df)

    return summary_df, diff_df


def build_effect_ranking(diff_df):
    if diff_df is None or len(diff_df) == 0:
        return pd.DataFrame()

    df = diff_df.copy()

    for metric in ["AF", "PAF", "RD"]:
        diff_col = f"Diff_Pooled_{metric}"
        ci_low_col = f"Bootstrap_{metric}_CI_low"
        ci_high_col = f"Bootstrap_{metric}_CI_high"
        q_col = f"Bootstrap_{metric}_q_global"
        sig_fdr_col = f"Bootstrap_{metric}_significant_FDR"

        pos_col = f"{metric}_positive_FDR"
        neg_col = f"{metric}_negative_FDR"

        if q_col in df.columns:
            df[pos_col] = (
                (df[diff_col] > 0) &
                (df[ci_low_col] > 0) &
                (df[q_col] < 0.05)
            )
            df[neg_col] = (
                (df[diff_col] < 0) &
                (df[ci_high_col] < 0) &
                (df[q_col] < 0.05)
            )
        elif sig_fdr_col in df.columns:
            df[pos_col] = (
                (df[diff_col] > 0) &
                (df[ci_low_col] > 0) &
                (df[sig_fdr_col])
            )
            df[neg_col] = (
                (df[diff_col] < 0) &
                (df[ci_high_col] < 0) &
                (df[sig_fdr_col])
            )
        else:
            df[pos_col] = False
            df[neg_col] = False

    df["Positive_effect_score"] = (
        df["AF_positive_FDR"].astype(int) +
        df["PAF_positive_FDR"].astype(int) +
        df["RD_positive_FDR"].astype(int)
    )

    df["Negative_effect_score"] = (
        df["AF_negative_FDR"].astype(int) +
        df["PAF_negative_FDR"].astype(int) +
        df["RD_negative_FDR"].astype(int)
    )

    df["Max_abs_effect_score"] = df[["Positive_effect_score", "Negative_effect_score"]].max(axis=1)

    df["Effect_direction"] = np.where(
        df["Positive_effect_score"] > df["Negative_effect_score"],
        "positive",
        np.where(
            df["Negative_effect_score"] > df["Positive_effect_score"],
            "negative",
            "mixed_or_not_significant"
        )
    )

    # 用 q 值排序。如果没有 q 值，则用 p 值。
    sort_cols = ["Max_abs_effect_score"]

    if "Bootstrap_AF_q_global" in df.columns:
        df["min_q_AF_RD_PAF"] = df[[
            "Bootstrap_AF_q_global",
            "Bootstrap_PAF_q_global",
            "Bootstrap_RD_q_global"
        ]].min(axis=1)
        sort_cols.append("min_q_AF_RD_PAF")
    else:
        df["min_p_AF_RD_PAF"] = df[[
            "Bootstrap_AF_p_two_sided",
            "Bootstrap_PAF_p_two_sided",
            "Bootstrap_RD_p_two_sided"
        ]].min(axis=1)
        sort_cols.append("min_p_AF_RD_PAF")

    df["Abs_Diff_AF"] = np.abs(df["Diff_Pooled_AF"])
    df["Abs_Diff_RD"] = np.abs(df["Diff_Pooled_RD"])
    df["Abs_Diff_PAF"] = np.abs(df["Diff_Pooled_PAF"])

    df = df.sort_values(
        by=sort_cols + ["Abs_Diff_AF", "Abs_Diff_RD", "Abs_Diff_PAF"],
        ascending=[False, True, False, False, False]
    )

    selected_cols = [
        "Mode", "Lag", "Lag_unit", "Comparison",
        "Phase1", "Phase2",
        "Effect_direction",
        "Positive_effect_score",
        "Negative_effect_score",
        "Max_abs_effect_score",

        "Diff_Pooled_AF",
        "Bootstrap_AF_CI_low",
        "Bootstrap_AF_CI_high",
        "Bootstrap_AF_p_two_sided",
        "Bootstrap_AF_q_global" if "Bootstrap_AF_q_global" in df.columns else None,

        "Diff_Pooled_PAF",
        "Bootstrap_PAF_CI_low",
        "Bootstrap_PAF_CI_high",
        "Bootstrap_PAF_p_two_sided",
        "Bootstrap_PAF_q_global" if "Bootstrap_PAF_q_global" in df.columns else None,

        "Diff_Pooled_RD",
        "Bootstrap_RD_CI_low",
        "Bootstrap_RD_CI_high",
        "Bootstrap_RD_p_two_sided",
        "Bootstrap_RD_q_global" if "Bootstrap_RD_q_global" in df.columns else None,

        "Phase1_pooled_AF",
        "Phase2_pooled_AF",
        "Phase1_pooled_PAF",
        "Phase2_pooled_PAF",
        "Phase1_pooled_RD",
        "Phase2_pooled_RD",
        "Phase1_pooled_AR_fraction",
        "Phase2_pooled_AR_fraction",
        "Time_points_phase1",
        "Time_points_phase2",
        "Bootstrap_blocks_phase1",
        "Bootstrap_blocks_phase2"
    ]

    selected_cols = [c for c in selected_cols if c is not None and c in df.columns]

    return df[selected_cols].copy()


def build_best_lag_by_comparison(ranking_df):
    if ranking_df is None or len(ranking_df) == 0:
        return pd.DataFrame()

    df = ranking_df.copy()

    # 每个 comparison 挑出分数最高、q/p 最小的 lag
    if "Bootstrap_AF_q_global" in df.columns:
        df["sort_q_or_p"] = df[[
            "Bootstrap_AF_q_global",
            "Bootstrap_PAF_q_global",
            "Bootstrap_RD_q_global"
        ]].min(axis=1)
    else:
        df["sort_q_or_p"] = df[[
            "Bootstrap_AF_p_two_sided",
            "Bootstrap_PAF_p_two_sided",
            "Bootstrap_RD_p_two_sided"
        ]].min(axis=1)

    df = df.sort_values(
        by=["Comparison", "Max_abs_effect_score", "sort_q_or_p", "Diff_Pooled_AF"],
        ascending=[True, False, True, False]
    )

    best = df.groupby("Comparison", as_index=False).head(1).copy()
    best = best.sort_values(
        by=["Max_abs_effect_score", "sort_q_or_p"],
        ascending=[False, True]
    )

    return best


