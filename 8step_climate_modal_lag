def pooled_point_from_counts(A, B, C, D):
    res = pooled_delta_ci(A, B, C, D)
    return {
        "RD": res["pooled_RD"],
        "RR": res["pooled_RR"],
        "AF": res["pooled_AF"],
        "PAF": res["pooled_PAF"]
    }


def build_month_blocks_for_bucket(labels, bucket, dates_pd, time_counts):
    labels = np.asarray(labels, dtype=object)
    idx = np.where(labels == bucket)[0]

    if idx.size == 0:
        return None

    dates_sel = pd.to_datetime(dates_pd[idx])
    months = dates_sel.to_period("M")

    block_rows = []

    for month in np.unique(months):
        block_idx = idx[months == month]

        block_rows.append({
            "month": str(month),
            "A": int(np.sum(time_counts["A"][block_idx])),
            "B": int(np.sum(time_counts["B"][block_idx])),
            "C": int(np.sum(time_counts["C"][block_idx])),
            "D": int(np.sum(time_counts["D"][block_idx])),
            "n_time": int(len(block_idx))
        })

    return pd.DataFrame(block_rows)


def bootstrap_pooled_difference(
    labels,
    bucket1,
    bucket2,
    dates_pd,
    time_counts,
    n_boot=500,
    seed=42
):
    rng = np.random.default_rng(seed)

    blocks1 = build_month_blocks_for_bucket(labels, bucket1, dates_pd, time_counts)
    blocks2 = build_month_blocks_for_bucket(labels, bucket2, dates_pd, time_counts)

    if blocks1 is None or blocks2 is None:
        return None

    if len(blocks1) < 3 or len(blocks2) < 3:
        return None

    boot_diffs = {
        "RD": [],
        "RR": [],
        "AF": [],
        "PAF": []
    }

    n1 = len(blocks1)
    n2 = len(blocks2)

    vals1 = blocks1[["A", "B", "C", "D"]].to_numpy()
    vals2 = blocks2[["A", "B", "C", "D"]].to_numpy()

    for _ in range(n_boot):
        sample1 = rng.integers(0, n1, size=n1)
        sample2 = rng.integers(0, n2, size=n2)

        A1, B1, C1, D1 = np.sum(vals1[sample1], axis=0)
        A2, B2, C2, D2 = np.sum(vals2[sample2], axis=0)

        m1 = pooled_point_from_counts(A1, B1, C1, D1)
        m2 = pooled_point_from_counts(A2, B2, C2, D2)

        for metric in boot_diffs:
            boot_diffs[metric].append(m1[metric] - m2[metric])

    out = {}

    for metric, diffs in boot_diffs.items():
        diffs = np.asarray(diffs, dtype=float)
        diffs = diffs[np.isfinite(diffs)]

        if diffs.size == 0:
            out[f"Bootstrap_{metric}_mean_diff"] = np.nan
            out[f"Bootstrap_{metric}_CI_low"] = np.nan
            out[f"Bootstrap_{metric}_CI_high"] = np.nan
            out[f"Bootstrap_{metric}_p_two_sided"] = np.nan
            out[f"Bootstrap_{metric}_significant"] = False
            continue

        ci_low, ci_high = np.percentile(diffs, [2.5, 97.5])

        p_two = 2 * min(
            np.mean(diffs <= 0),
            np.mean(diffs >= 0)
        )
        p_two = min(p_two, 1.0)

        out[f"Bootstrap_{metric}_mean_diff"] = float(np.mean(diffs))
        out[f"Bootstrap_{metric}_CI_low"] = float(ci_low)
        out[f"Bootstrap_{metric}_CI_high"] = float(ci_high)
        out[f"Bootstrap_{metric}_p_two_sided"] = float(p_two)
        out[f"Bootstrap_{metric}_significant"] = bool((ci_low > 0) or (ci_high < 0))

    out["Bootstrap_blocks_phase1"] = int(n1)
    out["Bootstrap_blocks_phase2"] = int(n2)

    return out


def get_phase_comparisons(mode, available_phases):
    available = set([str(x) for x in available_phases])

    if mode == "ENSO":
        pairs = [
            ("ElNino", "LaNina"),
            ("ElNino", "Neutral"),
            ("LaNina", "Neutral")
        ]

    elif mode == "AO":
        pairs = [
            ("Positive", "Negative"),
            ("Negative", "Neutral"),
            ("Positive", "Neutral")
        ]

    elif mode == "PDO":
        pairs = [
            ("Positive", "Negative"),
            ("Positive", "Neutral"),
            ("Neutral", "Negative")
        ]

    elif mode == "MJO":
        if MJO_PHASE_STYLE == "coarse":
            pairs = [
                ("Active_1to4", "Active_5to8"),
                ("Active_1to4", "Inactive"),
                ("Active_5to8", "Inactive")
            ]
        else:
            pairs = []
            for p in range(1, 9):
                pairs.append((f"Phase_{p}", "Inactive"))

            # 额外加入相邻相位差异，便于判断传播结构，但主要结论仍建议用 vs Inactive
            for p in range(1, 8):
                pairs.append((f"Phase_{p}", f"Phase_{p+1}"))

    else:
        pairs = []

    pairs = [(a, b) for a, b in pairs if a in available and b in available]
    return pairs


def compute_pairwise_differences_for_mode_lag(mode, lag, labels, summary_df, dates_pd, time_counts):
    if summary_df is None or len(summary_df) == 0:
        return pd.DataFrame()

    available_phases = summary_df["Phase"].astype(str).to_list()
    pairs = get_phase_comparisons(mode, available_phases)

    rows = []

    for phase1, phase2 in pairs:
        r1 = summary_df[summary_df["Phase"].astype(str) == phase1].iloc[0]
        r2 = summary_df[summary_df["Phase"].astype(str) == phase2].iloc[0]

        row = {
            "Mode": mode,
            "Lag": lag,
            "Lag_unit": MODE_LAG_UNIT[mode],
            "Phase1": phase1,
            "Phase2": phase2,
            "Comparison": f"{mode}: {phase1} - {phase2}",

            "Time_points_phase1": int(r1["Time_points"]),
            "Time_points_phase2": int(r2["Time_points"]),

            "Diff_Pooled_AF": r1["pooled_AF"] - r2["pooled_AF"],
            "Diff_Pooled_PAF": r1["pooled_PAF"] - r2["pooled_PAF"],
            "Diff_Pooled_RD": r1["pooled_RD"] - r2["pooled_RD"],
            "Diff_Pooled_RR": r1["pooled_RR"] - r2["pooled_RR"],

            "Phase1_pooled_AF": r1["pooled_AF"],
            "Phase2_pooled_AF": r2["pooled_AF"],
            "Phase1_pooled_PAF": r1["pooled_PAF"],
            "Phase2_pooled_PAF": r2["pooled_PAF"],
            "Phase1_pooled_RD": r1["pooled_RD"],
            "Phase2_pooled_RD": r2["pooled_RD"],
            "Phase1_pooled_AR_fraction": r1["pooled_AR_fraction"],
            "Phase2_pooled_AR_fraction": r2["pooled_AR_fraction"],
            "Phase1_pooled_EP_fraction": r1["pooled_EP_fraction"],
            "Phase2_pooled_EP_fraction": r2["pooled_EP_fraction"],
        }

        if RUN_BOOTSTRAP:
            boot = bootstrap_pooled_difference(
                labels=labels,
                bucket1=phase1,
                bucket2=phase2,
                dates_pd=dates_pd,
                time_counts=time_counts,
                n_boot=N_BOOT,
                seed=BOOTSTRAP_SEED + int(lag) + len(rows)
            )

            if boot is not None:
                row.update(boot)
            else:
                row["Bootstrap_note"] = "Not enough blocks or missing phase"

        rows.append(row)

    return pd.DataFrame(rows)


