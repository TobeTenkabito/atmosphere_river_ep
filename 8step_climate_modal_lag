    report_file = os.path.join(OUTPUT_DIR, "lag_scan_report.txt")
    excel_file = os.path.join(OUTPUT_DIR, "mode_lag_scan_tables.xlsx")

    summary_df.to_csv(summary_csv, index=False, encoding="utf-8-sig")
    diff_df.to_csv(diff_csv, index=False, encoding="utf-8-sig")
    ranking_df.to_csv(ranking_csv, index=False, encoding="utf-8-sig")
    best_df.to_csv(best_csv, index=False, encoding="utf-8-sig")

